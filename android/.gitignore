# Build outputs
build/
app/build/

# Gradle wrapper (keep wrapper jar, ignore generated files)
.gradle/
gradle/wrapper/gradle-wrapper.jar

# Kotlin compiler scratch/daemon output
.kotlin/

# Local config (machine-specific)
local.properties

# Signing material & build artifacts — never commit these
*.apk
*.aab
*.keystore
*.jks
keystore.properties

# IDE
.idea/
*.iml

# JVM crash dumps
*.hprof

# Android Studio Navigation editor temp files
.navigation/

# Generated files
app/src/main/assets/flutter_assets/
