# Copy to .env and fill in real values before `docker compose up`.

# Host paths (must exist before starting the stack)
MUSIC_DIR=./data/music
NAVIDROME_DATA=./data/navidrome

# Navidrome admin credentials.
# Used by the middleware to call Subsonic endpoints (proxy + startScan).
# Set these to whatever you'll create as the admin user on Navidrome's first-run page.
NAVIDROME_USER=admin
NAVIDROME_PASS=changeme

# Shared secret the web app sends as X-API-Key (or ?key=... for /api/stream).
# Generate with: openssl rand -hex 32
MIDDLEWARE_API_KEY=changeme-generate-a-random-string
