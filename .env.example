# ──────────────────────────────────────────────
#  Kobser – copy this file to .env and edit below
# ──────────────────────────────────────────────

# Absolute (or relative) path to your music folder on the host.
# This is where downloaded tracks will be stored.
MUSIC_DIR=./data/music

# Port Kobser is accessible on.  Open http://localhost:8000 after starting.
KOBSER_PORT=8000

# Port the Navidrome admin UI is accessible on.
# You only need this once, to create your account on first run.
NAVIDROME_PORT=4533

# ── Middleware-only mode (existing Navidrome) ────────────────────────────────
#
# If you already have Navidrome running, set this to its URL and start with:
#   docker compose up -d
# (omit --profile full — the navidrome service won't start)
#
# NAVIDROME_URL=http://your-navidrome-host:4533

# ── Optional ────────────────────────────────────────────────────────────────

# Path to a Netscape-format cookies.txt exported from your browser.
# Only needed to download age-restricted or region-locked YouTube videos.
# YTDLP_COOKIES_FILE=./secrets/cookies.txt
